# ============================================
# Bo-Distiller 环境变量配置示例
# ============================================

# LLM API Keys（至少配置一个）
# ============================================

# DeepSeek（推荐 - 最便宜，¥0.001/1K tokens）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Xiaomi Mimo（coding-plan 套餐）
MIMO_API_KEY=your_mimo_api_key_here

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here

# Kimi-code（coding-plan 套餐）
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书配置（可选）
# ============================================
# 飞书知识库空间 ID（在飞书知识库设置中获取）
FEISHU_SPACE_ID=your_feishu_space_id

# Cubox 配置（通过 Cubox CLI 配置，无需在此设置）
# ============================================
# 使用 `cubox config --token YOUR_TOKEN` 配置
